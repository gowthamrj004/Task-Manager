# Local Postgres (create DB first: CREATE DATABASE taskmanager;)
# Railway Postgres: use the variable Railway injects. If connections fail from outside Railway,
# append: ?sslmode=require (often already included in Railway's URL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskmanager"
JWT_SECRET="your_jwt_secret_key_change_this_in_production"
PORT=5001
NODE_ENV="development"
# One origin, or comma-separated: deployed SPA + local Vite (needed if you use localhost UI against Railway API)
FRONTEND_URL="http://localhost:5173"
# FRONTEND_URL="https://your-frontend.up.railway.app,http://localhost:5173"
