# REQUIRED for local dev: literal "/api" — do NOT use http://localhost:5173/register (breaks requests).
VITE_API_URL=/api
VITE_API_PROXY_TARGET=https://your-backend.up.railway.app

# Production build: full URL ending in /api
# VITE_API_URL=https://your-backend.up.railway.app/api

# Restart `npm run dev` after editing.
