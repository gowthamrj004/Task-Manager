# Preferred local dev: same-origin /api + Vite proxy (avoids CORS; works without a local Node API)
VITE_API_URL=/api
VITE_API_PROXY_TARGET=https://your-backend.up.railway.app

# If VITE_API_PROXY_TARGET is empty, proxy falls back to http://127.0.0.1:5001 (run backend locally).

# Production build on Railway/static host: set full API URL (must rebuild)
# VITE_API_URL=https://your-backend.up.railway.app/api

# Restart `npm run dev` after editing.
